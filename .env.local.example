# ── Vercel environment file template ──────────────────────
# Copy this file to .env.local and fill in your real key for local testing.
# NEVER commit .env.local to source control.
# Set GEMINI_API_KEY in the Vercel dashboard:
#   Project → Settings → Environment Variables → Add GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here
